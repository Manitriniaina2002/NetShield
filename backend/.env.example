# Backend Environment Variables
# Production Deployment (Render)

# Application Settings
DEBUG=false
LOG_LEVEL=INFO

# WiFi Scanning Mode
# Set to 'false' for real network scanning
# Set to 'true' for simulation mode (demo)
SIMULATION_MODE=false

# Server Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS - Allowed Origins
# Format: JSON array or comma-separated values
CORS_ORIGINS=[
  "https://your-frontend-domain.vercel.app",
  "http://localhost:3000",
  "http://localhost:5173"
]

# Company Name for Reports
COMPANY_NAME=NetShield Labs

# PDF Reports Directory
PDF_TEMP_DIR=./temp_reports

# Security Settings
REQUIRE_CONFIRMATION=true
